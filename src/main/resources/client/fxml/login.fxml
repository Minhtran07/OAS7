<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<BorderPane prefHeight="520.0" prefWidth="460.0"
            style="-fx-background-color: #f0f2f5;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.ControllerLogin">

    <center>
        <VBox alignment="CENTER" spacing="0"
              style="-fx-background-color: #f0f2f5;">

            <!-- Card -->
            <VBox spacing="20"
                  style="-fx-background-color: white; -fx-background-radius: 16;
                         -fx-padding: 40 44; -fx-max-width: 400;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.10), 20, 0, 0, 4);">
                <VBox.margin><Insets top="40" bottom="40" left="30" right="30"/></VBox.margin>

                <!-- Header -->
                <VBox spacing="6" alignment="CENTER">
                    <Label text="👋 Chào mừng trở lại"
                           style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a1a2e;" />
                    <Label text="Đăng nhập để tiếp tục đấu giá"
                           style="-fx-font-size: 13px; -fx-text-fill: #6c757d;" />
                </VBox>

                <!-- Username -->
                <VBox spacing="6">
                    <Label text="Tên đăng nhập"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #495057;" />
                    <TextField fx:id="usernameField" prefHeight="42.0"
                               promptText="Nhập tên đăng nhập"
                               style="-fx-background-color: #f8f9fa; -fx-background-radius: 8;
                                      -fx-border-color: #dee2e6; -fx-border-radius: 8;
                                      -fx-font-size: 13px; -fx-padding: 0 12;" />
                </VBox>

                <!-- Password -->
                <VBox spacing="6">
                    <Label text="Mật khẩu"
                           style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #495057;" />
                    <PasswordField fx:id="passwordField" prefHeight="42.0"
                                   promptText="Nhập mật khẩu"
                                   style="-fx-background-color: #f8f9fa; -fx-background-radius: 8;
                                          -fx-border-color: #dee2e6; -fx-border-radius: 8;
                                          -fx-font-size: 13px; -fx-padding: 0 12;" />
                </VBox>

                <!-- Error message -->
                <Label fx:id="messageLabel" text="" prefWidth="320.0"
                       style="-fx-text-fill: #e94560; -fx-font-size: 12px; -fx-background-color: #fff5f7;
                              -fx-background-radius: 6; -fx-padding: 8 12;"
                       wrapText="true" />

                <!-- Login button -->
                <Button fx:id="loginButton" prefHeight="44.0" prefWidth="400.0"
                        mnemonicParsing="false" onAction="#handleLogin" text="Đăng nhập"
                        style="-fx-background-color: #e94560; -fx-text-fill: white;
                               -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;
                               -fx-background-radius: 8;" />

                <!-- Divider -->
                <HBox alignment="CENTER" spacing="12">
                    <Region HBox.hgrow="ALWAYS" style="-fx-background-color: #dee2e6;" prefHeight="1"/>
                    <Label text="hoặc" style="-fx-text-fill: #adb5bd; -fx-font-size: 12px;" />
                    <Region HBox.hgrow="ALWAYS" style="-fx-background-color: #dee2e6;" prefHeight="1"/>
                </HBox>

                <!-- Register -->
                <Button prefHeight="44.0" prefWidth="400.0"
                        mnemonicParsing="false" onAction="#switchToRegister" text="Tạo tài khoản mới"
                        style="-fx-background-color: white; -fx-text-fill: #1a1a2e;
                               -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;
                               -fx-background-radius: 8; -fx-border-color: #dee2e6; -fx-border-radius: 8;" />

                <!-- Back -->
                <Button prefHeight="36.0" prefWidth="400.0"
                        mnemonicParsing="false" onAction="#switchToHome" text="← Quay về trang chủ"
                        style="-fx-background-color: transparent; -fx-text-fill: #6c757d;
                               -fx-font-size: 12px; -fx-cursor: hand; -fx-border-color: transparent;" />
            </VBox>
        </VBox>
    </center>
</BorderPane>
