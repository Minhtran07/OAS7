<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>

<BorderPane prefHeight="560.0" prefWidth="480.0"
            style="-fx-background-color: white;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.ControllerNotification">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="10"
              style="-fx-background-color: #1a1a2e; -fx-padding: 14 18;">
            <Label text="🔔  Thông báo"
                   style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;" />
            <Label fx:id="countLabel" text=""
                   style="-fx-text-fill: #adb5bd; -fx-font-size: 12px;" />
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Đánh dấu tất cả là đã đọc" onAction="#handleMarkAllRead"
                    style="-fx-background-color: #495057; -fx-text-fill: white;
                           -fx-font-size: 11px; -fx-font-weight: bold; -fx-cursor: hand;
                           -fx-background-radius: 6; -fx-padding: 6 10;" />
            <Button text="✕" onAction="#handleClose"
                    style="-fx-background-color: #e94560; -fx-text-fill: white;
                           -fx-font-size: 12px; -fx-font-weight: bold; -fx-cursor: hand;
                           -fx-background-radius: 6; -fx-padding: 6 10;" />
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox fx:id="listContainer" spacing="8"
                  style="-fx-background-color: #f8f9fa; -fx-padding: 12;" />
        </ScrollPane>
    </center>

    <bottom>
        <Label fx:id="emptyLabel" text="Chưa có thông báo nào."
               style="-fx-padding: 10; -fx-text-fill: #6c757d; -fx-font-size: 12px;"
               visible="false" managed="false" />
    </bottom>
</BorderPane>
