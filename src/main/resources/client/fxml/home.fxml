<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="580.0" prefWidth="700.0"
            style="-fx-background-color: #f0f2f5;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.ControllerHome">

    <!-- ─── NAVBAR ─── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #1a1a2e; -fx-padding: 0 24px;">
            <ImageView fitHeight="44.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
                <HBox.margin><Insets top="8" bottom="8" right="16"/></HBox.margin>
                <image><Image url="@../images/logo-uet.jpg" /></image>
            </ImageView>
            <Label text="BidNow"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-font-family: 'Arial';" />
            <Region HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#showHowToBuy" text="Cách mua"
                    style="-fx-background-color: transparent; -fx-text-fill: #adb5bd;
                           -fx-font-size: 13px; -fx-cursor: hand; -fx-border-color: transparent;" />
            <Button mnemonicParsing="false" onAction="#switchToLogin" text="Đăng nhập"
                    style="-fx-background-color: #e94560; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;
                           -fx-background-radius: 6; -fx-padding: 8 20;">
                <HBox.margin><Insets left="16"/></HBox.margin>
            </Button>
        </HBox>
    </top>

    <!-- ─── HERO ─── -->
    <center>
        <VBox alignment="CENTER" spacing="0"
              style="-fx-background-color: #f0f2f5;">

            <!-- Hero card -->
            <VBox alignment="CENTER" spacing="16"
                  style="-fx-background-color: linear-gradient(to bottom right, #1a1a2e, #16213e, #0f3460);
                         -fx-background-radius: 0; -fx-padding: 70 60 80 60;">
                <Label text="Đấu giá trực tuyến"
                       style="-fx-text-fill: white; -fx-font-size: 38px; -fx-font-weight: bold; -fx-font-family: 'Arial';" />
                <Label text="Mua và bán những sản phẩm độc đáo với giá tốt nhất"
                       style="-fx-text-fill: #adb5bd; -fx-font-size: 15px;" />

                <HBox alignment="CENTER" spacing="16">
                    <VBox.margin><Insets top="16"/></VBox.margin>
                    <Button mnemonicParsing="false" onAction="#switchToLogin" text="🔨  Xem đấu giá"
                            style="-fx-background-color: #e94560; -fx-text-fill: white;
                                   -fx-font-size: 15px; -fx-font-weight: bold; -fx-cursor: hand;
                                   -fx-background-radius: 8; -fx-padding: 12 32;" />
                    <Button mnemonicParsing="false" onAction="#showGuide" text="📖  Hướng dẫn"
                            style="-fx-background-color: transparent; -fx-text-fill: white;
                                   -fx-font-size: 15px; -fx-cursor: hand;
                                   -fx-background-radius: 8; -fx-padding: 12 32;
                                   -fx-border-color: white; -fx-border-radius: 8;" />
                </HBox>
            </VBox>

            <!-- Feature highlights bar (thay cho stats bịa đặt) -->
            <HBox alignment="CENTER" spacing="0"
                  style="-fx-background-color: white; -fx-border-color: #e9ecef; -fx-border-width: 0 0 1 0;">
                <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                    <padding><Insets top="20" bottom="20"/></padding>
                    <Label text="⚡"
                           style="-fx-font-size: 24px;" />
                    <Label text="Thời gian thực"
                           style="-fx-font-size: 12px; -fx-text-fill: #6c757d;" />
                </VBox>
                <Region style="-fx-background-color: #e9ecef;" prefWidth="1" prefHeight="60"/>
                <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                    <padding><Insets top="20" bottom="20"/></padding>
                    <Label text="🔒"
                           style="-fx-font-size: 24px;" />
                    <Label text="An toàn &amp; minh bạch"
                           style="-fx-font-size: 12px; -fx-text-fill: #6c757d;" />
                </VBox>
                <Region style="-fx-background-color: #e9ecef;" prefWidth="1" prefHeight="60"/>
                <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS">
                    <padding><Insets top="20" bottom="20"/></padding>
                    <Label text="🤖"
                           style="-fx-font-size: 24px;" />
                    <Label text="Tự động đấu giá"
                           style="-fx-font-size: 12px; -fx-text-fill: #6c757d;" />
                </VBox>
            </HBox>

            <!-- Feature cards -->
            <HBox spacing="16" alignment="CENTER"
                  style="-fx-background-color: #f0f2f5; -fx-padding: 32 48;">
                <VBox spacing="8" alignment="CENTER" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                    <Label text="🎨" style="-fx-font-size: 28px;" />
                    <Label text="Nghệ thuật" style="-fx-font-weight: bold; -fx-font-size: 13px;" />
                    <Label text="Tranh, tác phẩm độc đáo" style="-fx-text-fill: #6c757d; -fx-font-size: 11px;" />
                </VBox>
                <VBox spacing="8" alignment="CENTER" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                    <Label text="💻" style="-fx-font-size: 28px;" />
                    <Label text="Điện tử" style="-fx-font-weight: bold; -fx-font-size: 13px;" />
                    <Label text="Thiết bị công nghệ" style="-fx-text-fill: #6c757d; -fx-font-size: 11px;" />
                </VBox>
                <VBox spacing="8" alignment="CENTER" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                    <Label text="🚗" style="-fx-font-size: 28px;" />
                    <Label text="Xe cộ" style="-fx-font-weight: bold; -fx-font-size: 13px;" />
                    <Label text="Ô tô, xe máy" style="-fx-text-fill: #6c757d; -fx-font-size: 11px;" />
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>
